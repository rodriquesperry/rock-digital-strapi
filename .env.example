HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified

DATABASE_CLIENT=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=strapi
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_SSL=false

# Optional SSL settings for hosted/prod MySQL
# DATABASE_SSL=true
# DATABASE_SSL_SELF=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_CA_PATH=./config/ssl/ca-certificate.crt
# CA_CERT_BASE64=

# Optional DigitalOcean Spaces-backed media storage
# When SPACES_BUCKET is unset, Strapi falls back to local ./public/uploads storage.
# In production, SPACES_BUCKET is required unless ALLOW_LOCAL_UPLOADS=true.
# SPACES_BUCKET=your-space-name
# SPACES_REGION=nyc3
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_BASE_URL=https://your-space-name.nyc3.digitaloceanspaces.com
# SPACES_ACCESS_KEY=
# SPACES_SECRET_KEY=
# Also supported: SPACES_ACCESS_KEY_ID / SPACES_SECRET_ACCESS_KEY or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# SPACES_SIGNING_REGION=us-east-1
# SPACES_ROOT_PATH=uploads
# SPACES_ACL=public-read
# SPACES_SIGNED_URL_EXPIRES=900
# SPACES_CACHE_CONTROL=public, max-age=31536000, immutable
# ALLOW_LOCAL_UPLOADS=false

# Development entrypoints:
# npm run develop uses .env
# npm run develop:local preloads .local.env explicitly.
